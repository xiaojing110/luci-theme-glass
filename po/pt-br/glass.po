#: ucode/template/themes/glass/sysauth.ut:50
msgid "Login"
msgstr "Login"

#: ucode/template/themes/glass/sysauth.ut:104
msgid "Sign in to continue"
msgstr "Faça login para continuar"

#: ucode/template/themes/glass/sysauth.ut:109
msgid "Invalid username and/or password! Please try again."
msgstr "Usuário e/ou senha inválidos! Tente novamente."

#: ucode/template/themes/glass/sysauth.ut:115
msgid "Username"
msgstr "Usuário"

#: ucode/template/themes/glass/sysauth.ut:122
msgid "Password"
msgstr "Senha"

#: ucode/template/themes/glass/sysauth.ut:127
msgid "Log in"
msgstr "Entrar"

#: ucode/template/themes/glass/header.ut:176
msgid "No password set!"
msgstr "Nenhuma senha definida!"

#: ucode/template/themes/glass/header.ut:177
msgid "There is no password set on this router. Please configure a root password to protect the web interface."
msgstr "Nenhuma senha foi definida neste roteador. Configure uma senha root para proteger a interface web."

#: ucode/template/themes/glass/header.ut:179
msgid "Go to password configuration..."
msgstr "Ir para a configuração de senha..."

#: ucode/template/themes/glass/header.ut:186
msgid "JavaScript required!"
msgstr "JavaScript necessário!"

#: ucode/template/themes/glass/header.ut:187
msgid "You must enable JavaScript in your browser or LuCI will not work properly."
msgstr "Você deve habilitar JavaScript no seu navegador ou o LuCI não funcionará corretamente."

#: htdocs/luci-static/resources/view/system/glass.js
msgid "Glass Theme"
msgstr "Tema Glass"

#: htdocs/luci-static/resources/view/system/glass.js
msgid "Configure the appearance of the Glass theme. Changes take effect after saving and refreshing the page."
msgstr "Configure a aparência do tema Glass. As alterações entram em vigor após salvar e atualizar a página."

#: htdocs/luci-static/resources/view/system/glass.js
msgid "General"
msgstr "Geral"

#: htdocs/luci-static/resources/view/system/glass.js
msgid "Theme mode"
msgstr "Modo do tema"

#: htdocs/luci-static/resources/view/system/glass.js
msgid "Controls the overall appearance. \"Normal\" follows the system preference."
msgstr "Controla a aparência geral. «Automático» segue a preferência do sistema."

#: htdocs/luci-static/resources/view/system/glass.js
msgid "Auto (follow system)"
msgstr "Automático (seguir sistema)"

#: htdocs/luci-static/resources/view/system/glass.js
msgid "Light"
msgstr "Claro"

#: htdocs/luci-static/resources/view/system/glass.js
msgid "Dark"
msgstr "Escuro"

#: htdocs/luci-static/resources/view/system/glass.js
msgid "Header status bar"
msgstr "Barra de status do cabeçalho"

#: htdocs/luci-static/resources/view/system/glass.js
msgid "Show live system stats (CPU, RAM, network, uptime) in the header. Disable to reduce resource usage on low-end devices."
msgstr "Mostrar estatísticas do sistema em tempo real (CPU, RAM, rede, tempo de atividade) no cabeçalho. Desative para reduzir o uso de recursos em dispositivos de baixo desempenho."

#: htdocs/luci-static/resources/view/system/glass.js
msgid "Base font size"
msgstr "Tamanho base da fonte"

#: htdocs/luci-static/resources/view/system/glass.js
msgid "Scales all text in the theme. Larger values improve readability on high-DPI displays."
msgstr "Escala todo o texto do tema. Valores maiores melhoram a legibilidade em telas de alta resolução."

#: htdocs/luci-static/resources/view/system/glass.js
msgid "Small (13px)"
msgstr "Pequeno (13px)"

#: htdocs/luci-static/resources/view/system/glass.js
msgid "Normal (14px)"
msgstr "Normal (14px)"

#: htdocs/luci-static/resources/view/system/glass.js
msgid "Large (16px)"
msgstr "Grande (16px)"

#: htdocs/luci-static/resources/view/system/glass.js
msgid "Extra Large (18px)"
msgstr "Muito grande (18px)"

#: htdocs/luci-static/resources/view/system/glass.js
msgid "Accent Colors"
msgstr "Cores de destaque"

#: htdocs/luci-static/resources/view/system/glass.js
msgid "Primary color (light mode)"
msgstr "Cor principal (modo claro)"

#: htdocs/luci-static/resources/view/system/glass.js
msgid "Accent color used for active elements, links, and buttons in light mode."
msgstr "Cor de destaque para elementos ativos, links e botões no modo claro."

#: htdocs/luci-static/resources/view/system/glass.js
msgid "Primary color (dark mode)"
msgstr "Cor principal (modo escuro)"

#: htdocs/luci-static/resources/view/system/glass.js
msgid "Accent color used for active elements, links, and buttons in dark mode."
msgstr "Cor de destaque para elementos ativos, links e botões no modo escuro."

#: htdocs/luci-static/resources/view/system/glass.js
msgid "Glass Effects — Light Mode"
msgstr "Efeitos de vidro — Modo claro"

#: htdocs/luci-static/resources/view/system/glass.js
msgid "Blur intensity (px)"
msgstr "Intensidade do desfoque (px)"

#: htdocs/luci-static/resources/view/system/glass.js
msgid "Backdrop blur radius for glass panels. Higher values create a more frosted appearance."
msgstr "Raio de desfoque do fundo para painéis de vidro. Valores maiores criam uma aparência mais fosca."

#: htdocs/luci-static/resources/view/system/glass.js
msgid "Panel transparency"
msgstr "Transparência do painel"

#: htdocs/luci-static/resources/view/system/glass.js
msgid "Background opacity of glass panels (0 = fully transparent, 1 = fully opaque)."
msgstr "Opacidade do fundo dos painéis de vidro (0 = totalmente transparente, 1 = totalmente opaco)."

#: htdocs/luci-static/resources/view/system/glass.js
msgid "Glass Effects — Dark Mode"
msgstr "Efeitos de vidro — Modo escuro"

#: htdocs/luci-static/resources/view/system/glass.js
msgid "Backdrop blur radius for glass panels in dark mode."
msgstr "Raio de desfoque do fundo para painéis de vidro no modo escuro."

#: htdocs/luci-static/resources/view/system/glass.js
msgid "Background opacity of glass panels in dark mode (0 = fully transparent, 1 = fully opaque)."
msgstr "Opacidade do fundo dos painéis de vidro no modo escuro (0 = totalmente transparente, 1 = totalmente opaco)."

#: htdocs/luci-static/resources/view/system/glass.js
msgid "Background"
msgstr "Fundo"

#: htdocs/luci-static/resources/view/system/glass.js
msgid "Current background"
msgstr "Fundo atual"

#: htdocs/luci-static/resources/view/system/glass.js
msgid "Active"
msgstr "Ativo"

#: htdocs/luci-static/resources/view/system/glass.js
msgid "No background set. Upload an image or video named \"bg\" (e.g. bg.jpg, bg.png, bg.mp4) to /www/luci-static/glass/background/ via SCP."
msgstr "Nenhum fundo definido. Envie uma imagem ou vídeo chamado «bg» (ex.: bg.jpg, bg.png, bg.mp4) para /www/luci-static/glass/background/ via SCP."
