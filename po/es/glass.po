#: ucode/template/themes/glass/sysauth.ut:50
msgid "Login"
msgstr "Iniciar sesión"

#: ucode/template/themes/glass/sysauth.ut:104
msgid "Sign in to continue"
msgstr "Inicia sesión para continuar"

#: ucode/template/themes/glass/sysauth.ut:109
msgid "Invalid username and/or password! Please try again."
msgstr "Usuario y/o contraseña no válidos. Inténtalo de nuevo."

#: ucode/template/themes/glass/sysauth.ut:115
msgid "Username"
msgstr "Usuario"

#: ucode/template/themes/glass/sysauth.ut:122
msgid "Password"
msgstr "Contraseña"

#: ucode/template/themes/glass/sysauth.ut:127
msgid "Log in"
msgstr "Iniciar sesión"

#: ucode/template/themes/glass/header.ut:176
msgid "No password set!"
msgstr "¡No se ha establecido contraseña!"

#: ucode/template/themes/glass/header.ut:177
msgid "There is no password set on this router. Please configure a root password to protect the web interface."
msgstr "Este router no tiene contraseña configurada. Configura una contraseña de root para proteger la interfaz web."

#: ucode/template/themes/glass/header.ut:179
msgid "Go to password configuration..."
msgstr "Ir a la configuración de contraseña..."

#: ucode/template/themes/glass/header.ut:186
msgid "JavaScript required!"
msgstr "¡Se requiere JavaScript!"

#: ucode/template/themes/glass/header.ut:187
msgid "You must enable JavaScript in your browser or LuCI will not work properly."
msgstr "Debes habilitar JavaScript en tu navegador o LuCI no funcionará correctamente."

#: htdocs/luci-static/resources/view/system/glass.js
msgid "Glass Theme"
msgstr "Tema Glass"

#: htdocs/luci-static/resources/view/system/glass.js
msgid "Configure the appearance of the Glass theme. Changes take effect after saving and refreshing the page."
msgstr "Configura la apariencia del tema Glass. Los cambios se aplican después de guardar y actualizar la página."

#: htdocs/luci-static/resources/view/system/glass.js
msgid "General"
msgstr "General"

#: htdocs/luci-static/resources/view/system/glass.js
msgid "Theme mode"
msgstr "Modo del tema"

#: htdocs/luci-static/resources/view/system/glass.js
msgid "Controls the overall appearance. \"Normal\" follows the system preference."
msgstr "Controla la apariencia general. «Automático» sigue la preferencia del sistema."

#: htdocs/luci-static/resources/view/system/glass.js
msgid "Auto (follow system)"
msgstr "Automático (seguir sistema)"

#: htdocs/luci-static/resources/view/system/glass.js
msgid "Light"
msgstr "Claro"

#: htdocs/luci-static/resources/view/system/glass.js
msgid "Dark"
msgstr "Oscuro"

#: htdocs/luci-static/resources/view/system/glass.js
msgid "Header status bar"
msgstr "Barra de estado del encabezado"

#: htdocs/luci-static/resources/view/system/glass.js
msgid "Show live system stats (CPU, RAM, network, uptime) in the header. Disable to reduce resource usage on low-end devices."
msgstr "Mostrar estadísticas del sistema en tiempo real (CPU, RAM, red, tiempo de actividad) en el encabezado. Desactivar para reducir el uso de recursos en dispositivos de gama baja."

#: htdocs/luci-static/resources/view/system/glass.js
msgid "Base font size"
msgstr "Tamaño de fuente base"

#: htdocs/luci-static/resources/view/system/glass.js
msgid "Scales all text in the theme. Larger values improve readability on high-DPI displays."
msgstr "Escala todo el texto del tema. Valores más grandes mejoran la legibilidad en pantallas de alta resolución."

#: htdocs/luci-static/resources/view/system/glass.js
msgid "Small (13px)"
msgstr "Pequeño (13px)"

#: htdocs/luci-static/resources/view/system/glass.js
msgid "Normal (14px)"
msgstr "Normal (14px)"

#: htdocs/luci-static/resources/view/system/glass.js
msgid "Large (16px)"
msgstr "Grande (16px)"

#: htdocs/luci-static/resources/view/system/glass.js
msgid "Extra Large (18px)"
msgstr "Muy grande (18px)"

#: htdocs/luci-static/resources/view/system/glass.js
msgid "Accent Colors"
msgstr "Colores de acento"

#: htdocs/luci-static/resources/view/system/glass.js
msgid "Primary color (light mode)"
msgstr "Color principal (modo claro)"

#: htdocs/luci-static/resources/view/system/glass.js
msgid "Accent color used for active elements, links, and buttons in light mode."
msgstr "Color de acento para elementos activos, enlaces y botones en modo claro."

#: htdocs/luci-static/resources/view/system/glass.js
msgid "Primary color (dark mode)"
msgstr "Color principal (modo oscuro)"

#: htdocs/luci-static/resources/view/system/glass.js
msgid "Accent color used for active elements, links, and buttons in dark mode."
msgstr "Color de acento para elementos activos, enlaces y botones en modo oscuro."

#: htdocs/luci-static/resources/view/system/glass.js
msgid "Glass Effects — Light Mode"
msgstr "Efectos de cristal — Modo claro"

#: htdocs/luci-static/resources/view/system/glass.js
msgid "Blur intensity (px)"
msgstr "Intensidad de desenfoque (px)"

#: htdocs/luci-static/resources/view/system/glass.js
msgid "Backdrop blur radius for glass panels. Higher values create a more frosted appearance."
msgstr "Radio de desenfoque del fondo para paneles de cristal. Valores más altos crean una apariencia más esmerilada."

#: htdocs/luci-static/resources/view/system/glass.js
msgid "Panel transparency"
msgstr "Transparencia del panel"

#: htdocs/luci-static/resources/view/system/glass.js
msgid "Background opacity of glass panels (0 = fully transparent, 1 = fully opaque)."
msgstr "Opacidad del fondo de los paneles de cristal (0 = totalmente transparente, 1 = totalmente opaco)."

#: htdocs/luci-static/resources/view/system/glass.js
msgid "Glass Effects — Dark Mode"
msgstr "Efectos de cristal — Modo oscuro"

#: htdocs/luci-static/resources/view/system/glass.js
msgid "Backdrop blur radius for glass panels in dark mode."
msgstr "Radio de desenfoque del fondo para paneles de cristal en modo oscuro."

#: htdocs/luci-static/resources/view/system/glass.js
msgid "Background opacity of glass panels in dark mode (0 = fully transparent, 1 = fully opaque)."
msgstr "Opacidad del fondo de los paneles de cristal en modo oscuro (0 = totalmente transparente, 1 = totalmente opaco)."

#: htdocs/luci-static/resources/view/system/glass.js
msgid "Background"
msgstr "Fondo"

#: htdocs/luci-static/resources/view/system/glass.js
msgid "Current background"
msgstr "Fondo actual"

#: htdocs/luci-static/resources/view/system/glass.js
msgid "Active"
msgstr "Activo"

#: htdocs/luci-static/resources/view/system/glass.js
msgid "No background set. Upload an image or video named \"bg\" (e.g. bg.jpg, bg.png, bg.mp4) to /www/luci-static/glass/background/ via SCP."
msgstr "No se ha establecido un fondo. Sube una imagen o vídeo llamado «bg» (p. ej., bg.jpg, bg.png, bg.mp4) a /www/luci-static/glass/background/ mediante SCP."
