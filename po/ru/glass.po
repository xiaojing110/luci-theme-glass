#: ucode/template/themes/glass/sysauth.ut:50
msgid "Login"
msgstr "Вход"

#: ucode/template/themes/glass/sysauth.ut:104
msgid "Sign in to continue"
msgstr "Войдите для продолжения"

#: ucode/template/themes/glass/sysauth.ut:109
msgid "Invalid username and/or password! Please try again."
msgstr "Неверное имя пользователя и/или пароль! Попробуйте ещё раз."

#: ucode/template/themes/glass/sysauth.ut:115
msgid "Username"
msgstr "Имя пользователя"

#: ucode/template/themes/glass/sysauth.ut:122
msgid "Password"
msgstr "Пароль"

#: ucode/template/themes/glass/sysauth.ut:127
msgid "Log in"
msgstr "Войти"

#: ucode/template/themes/glass/header.ut:176
msgid "No password set!"
msgstr "Пароль не задан!"

#: ucode/template/themes/glass/header.ut:177
msgid "There is no password set on this router. Please configure a root password to protect the web interface."
msgstr "На этом роутере не задан пароль. Настройте пароль root для защиты веб-интерфейса."

#: ucode/template/themes/glass/header.ut:179
msgid "Go to password configuration..."
msgstr "Перейти к настройке пароля..."

#: ucode/template/themes/glass/header.ut:186
msgid "JavaScript required!"
msgstr "Требуется JavaScript!"

#: ucode/template/themes/glass/header.ut:187
msgid "You must enable JavaScript in your browser or LuCI will not work properly."
msgstr "Включите JavaScript в браузере, иначе LuCI не будет работать корректно."

#: htdocs/luci-static/resources/view/system/glass.js
msgid "Glass Theme"
msgstr "Тема Glass"

#: htdocs/luci-static/resources/view/system/glass.js
msgid "Configure the appearance of the Glass theme. Changes take effect after saving and refreshing the page."
msgstr "Настройте внешний вид темы Glass. Изменения вступают в силу после сохранения и обновления страницы."

#: htdocs/luci-static/resources/view/system/glass.js
msgid "General"
msgstr "Общие"

#: htdocs/luci-static/resources/view/system/glass.js
msgid "Theme mode"
msgstr "Режим темы"

#: htdocs/luci-static/resources/view/system/glass.js
msgid "Controls the overall appearance. \"Normal\" follows the system preference."
msgstr "Управляет общим видом. «Авто» следует системным настройкам."

#: htdocs/luci-static/resources/view/system/glass.js
msgid "Auto (follow system)"
msgstr "Авто (по системе)"

#: htdocs/luci-static/resources/view/system/glass.js
msgid "Light"
msgstr "Светлая"

#: htdocs/luci-static/resources/view/system/glass.js
msgid "Dark"
msgstr "Тёмная"

#: htdocs/luci-static/resources/view/system/glass.js
msgid "Header status bar"
msgstr "Строка состояния в шапке"

#: htdocs/luci-static/resources/view/system/glass.js
msgid "Show live system stats (CPU, RAM, network, uptime) in the header. Disable to reduce resource usage on low-end devices."
msgstr "Показывать статистику системы (ЦП, ОЗУ, сеть, время работы) в шапке. Отключите для снижения нагрузки на слабых устройствах."

#: htdocs/luci-static/resources/view/system/glass.js
msgid "Base font size"
msgstr "Базовый размер шрифта"

#: htdocs/luci-static/resources/view/system/glass.js
msgid "Scales all text in the theme. Larger values improve readability on high-DPI displays."
msgstr "Масштабирует весь текст в теме. Большие значения улучшают читаемость на экранах с высоким разрешением."

#: htdocs/luci-static/resources/view/system/glass.js
msgid "Small (13px)"
msgstr "Мелкий (13px)"

#: htdocs/luci-static/resources/view/system/glass.js
msgid "Normal (14px)"
msgstr "Обычный (14px)"

#: htdocs/luci-static/resources/view/system/glass.js
msgid "Large (16px)"
msgstr "Крупный (16px)"

#: htdocs/luci-static/resources/view/system/glass.js
msgid "Extra Large (18px)"
msgstr "Очень крупный (18px)"

#: htdocs/luci-static/resources/view/system/glass.js
msgid "Accent Colors"
msgstr "Акцентные цвета"

#: htdocs/luci-static/resources/view/system/glass.js
msgid "Primary color (light mode)"
msgstr "Основной цвет (светлый режим)"

#: htdocs/luci-static/resources/view/system/glass.js
msgid "Accent color used for active elements, links, and buttons in light mode."
msgstr "Акцентный цвет для активных элементов, ссылок и кнопок в светлом режиме."

#: htdocs/luci-static/resources/view/system/glass.js
msgid "Primary color (dark mode)"
msgstr "Основной цвет (тёмный режим)"

#: htdocs/luci-static/resources/view/system/glass.js
msgid "Accent color used for active elements, links, and buttons in dark mode."
msgstr "Акцентный цвет для активных элементов, ссылок и кнопок в тёмном режиме."

#: htdocs/luci-static/resources/view/system/glass.js
msgid "Glass Effects — Light Mode"
msgstr "Эффекты стекла — Светлый режим"

#: htdocs/luci-static/resources/view/system/glass.js
msgid "Blur intensity (px)"
msgstr "Интенсивность размытия (px)"

#: htdocs/luci-static/resources/view/system/glass.js
msgid "Backdrop blur radius for glass panels. Higher values create a more frosted appearance."
msgstr "Радиус размытия фона для стеклянных панелей. Большее значение создаёт более матовый эффект."

#: htdocs/luci-static/resources/view/system/glass.js
msgid "Panel transparency"
msgstr "Прозрачность панели"

#: htdocs/luci-static/resources/view/system/glass.js
msgid "Background opacity of glass panels (0 = fully transparent, 1 = fully opaque)."
msgstr "Непрозрачность фона стеклянных панелей (0 = полностью прозрачный, 1 = полностью непрозрачный)."

#: htdocs/luci-static/resources/view/system/glass.js
msgid "Glass Effects — Dark Mode"
msgstr "Эффекты стекла — Тёмный режим"

#: htdocs/luci-static/resources/view/system/glass.js
msgid "Backdrop blur radius for glass panels in dark mode."
msgstr "Радиус размытия фона для стеклянных панелей в тёмном режиме."

#: htdocs/luci-static/resources/view/system/glass.js
msgid "Background opacity of glass panels in dark mode (0 = fully transparent, 1 = fully opaque)."
msgstr "Непрозрачность фона стеклянных панелей в тёмном режиме (0 = полностью прозрачный, 1 = полностью непрозрачный)."

#: htdocs/luci-static/resources/view/system/glass.js
msgid "Background"
msgstr "Фон"

#: htdocs/luci-static/resources/view/system/glass.js
msgid "Current background"
msgstr "Текущий фон"

#: htdocs/luci-static/resources/view/system/glass.js
msgid "Active"
msgstr "Активен"

#: htdocs/luci-static/resources/view/system/glass.js
msgid "No background set. Upload an image or video named \"bg\" (e.g. bg.jpg, bg.png, bg.mp4) to /www/luci-static/glass/background/ via SCP."
msgstr "Фон не задан. Загрузите изображение или видео с именем «bg» (например, bg.jpg, bg.png, bg.mp4) в /www/luci-static/glass/background/ через SCP."
