#: ucode/template/themes/glass/sysauth.ut:50
msgid "Login"
msgstr "Connexion"

#: ucode/template/themes/glass/sysauth.ut:104
msgid "Sign in to continue"
msgstr "Connectez-vous pour continuer"

#: ucode/template/themes/glass/sysauth.ut:109
msgid "Invalid username and/or password! Please try again."
msgstr "Nom d'utilisateur et/ou mot de passe invalide ! Veuillez réessayer."

#: ucode/template/themes/glass/sysauth.ut:115
msgid "Username"
msgstr "Nom d'utilisateur"

#: ucode/template/themes/glass/sysauth.ut:122
msgid "Password"
msgstr "Mot de passe"

#: ucode/template/themes/glass/sysauth.ut:127
msgid "Log in"
msgstr "Se connecter"

#: ucode/template/themes/glass/header.ut:176
msgid "No password set!"
msgstr "Aucun mot de passe défini !"

#: ucode/template/themes/glass/header.ut:177
msgid "There is no password set on this router. Please configure a root password to protect the web interface."
msgstr "Aucun mot de passe n'est défini sur ce routeur. Veuillez configurer un mot de passe root pour protéger l'interface web."

#: ucode/template/themes/glass/header.ut:179
msgid "Go to password configuration..."
msgstr "Aller à la configuration du mot de passe..."

#: ucode/template/themes/glass/header.ut:186
msgid "JavaScript required!"
msgstr "JavaScript requis !"

#: ucode/template/themes/glass/header.ut:187
msgid "You must enable JavaScript in your browser or LuCI will not work properly."
msgstr "Vous devez activer JavaScript dans votre navigateur, sinon LuCI ne fonctionnera pas correctement."

#: htdocs/luci-static/resources/view/system/glass.js
msgid "Glass Theme"
msgstr "Thème Glass"

#: htdocs/luci-static/resources/view/system/glass.js
msgid "Configure the appearance of the Glass theme. Changes take effect after saving and refreshing the page."
msgstr "Configurez l'apparence du thème Glass. Les modifications prennent effet après l'enregistrement et l'actualisation de la page."

#: htdocs/luci-static/resources/view/system/glass.js
msgid "General"
msgstr "Général"

#: htdocs/luci-static/resources/view/system/glass.js
msgid "Theme mode"
msgstr "Mode du thème"

#: htdocs/luci-static/resources/view/system/glass.js
msgid "Controls the overall appearance. \"Normal\" follows the system preference."
msgstr "Contrôle l'apparence générale. «Automatique» suit les préférences du système."

#: htdocs/luci-static/resources/view/system/glass.js
msgid "Auto (follow system)"
msgstr "Automatique (suivre le système)"

#: htdocs/luci-static/resources/view/system/glass.js
msgid "Light"
msgstr "Clair"

#: htdocs/luci-static/resources/view/system/glass.js
msgid "Dark"
msgstr "Sombre"

#: htdocs/luci-static/resources/view/system/glass.js
msgid "Header status bar"
msgstr "Barre d'état de l'en-tête"

#: htdocs/luci-static/resources/view/system/glass.js
msgid "Show live system stats (CPU, RAM, network, uptime) in the header. Disable to reduce resource usage on low-end devices."
msgstr "Afficher les statistiques système en temps réel (CPU, RAM, réseau, temps de fonctionnement) dans l'en-tête. Désactiver pour réduire l'utilisation des ressources sur les appareils d'entrée de gamme."

#: htdocs/luci-static/resources/view/system/glass.js
msgid "Base font size"
msgstr "Taille de police de base"

#: htdocs/luci-static/resources/view/system/glass.js
msgid "Scales all text in the theme. Larger values improve readability on high-DPI displays."
msgstr "Met à l'échelle tout le texte du thème. Des valeurs plus grandes améliorent la lisibilité sur les écrans haute résolution."

#: htdocs/luci-static/resources/view/system/glass.js
msgid "Small (13px)"
msgstr "Petit (13px)"

#: htdocs/luci-static/resources/view/system/glass.js
msgid "Normal (14px)"
msgstr "Normal (14px)"

#: htdocs/luci-static/resources/view/system/glass.js
msgid "Large (16px)"
msgstr "Grand (16px)"

#: htdocs/luci-static/resources/view/system/glass.js
msgid "Extra Large (18px)"
msgstr "Très grand (18px)"

#: htdocs/luci-static/resources/view/system/glass.js
msgid "Accent Colors"
msgstr "Couleurs d'accentuation"

#: htdocs/luci-static/resources/view/system/glass.js
msgid "Primary color (light mode)"
msgstr "Couleur principale (mode clair)"

#: htdocs/luci-static/resources/view/system/glass.js
msgid "Accent color used for active elements, links, and buttons in light mode."
msgstr "Couleur d'accentuation pour les éléments actifs, les liens et les boutons en mode clair."

#: htdocs/luci-static/resources/view/system/glass.js
msgid "Primary color (dark mode)"
msgstr "Couleur principale (mode sombre)"

#: htdocs/luci-static/resources/view/system/glass.js
msgid "Accent color used for active elements, links, and buttons in dark mode."
msgstr "Couleur d'accentuation pour les éléments actifs, les liens et les boutons en mode sombre."

#: htdocs/luci-static/resources/view/system/glass.js
msgid "Glass Effects — Light Mode"
msgstr "Effets de verre — Mode clair"

#: htdocs/luci-static/resources/view/system/glass.js
msgid "Blur intensity (px)"
msgstr "Intensité du flou (px)"

#: htdocs/luci-static/resources/view/system/glass.js
msgid "Backdrop blur radius for glass panels. Higher values create a more frosted appearance."
msgstr "Rayon de flou d'arrière-plan pour les panneaux en verre. Des valeurs plus élevées créent un aspect plus dépoli."

#: htdocs/luci-static/resources/view/system/glass.js
msgid "Panel transparency"
msgstr "Transparence du panneau"

#: htdocs/luci-static/resources/view/system/glass.js
msgid "Background opacity of glass panels (0 = fully transparent, 1 = fully opaque)."
msgstr "Opacité de l'arrière-plan des panneaux en verre (0 = totalement transparent, 1 = totalement opaque)."

#: htdocs/luci-static/resources/view/system/glass.js
msgid "Glass Effects — Dark Mode"
msgstr "Effets de verre — Mode sombre"

#: htdocs/luci-static/resources/view/system/glass.js
msgid "Backdrop blur radius for glass panels in dark mode."
msgstr "Rayon de flou d'arrière-plan pour les panneaux en verre en mode sombre."

#: htdocs/luci-static/resources/view/system/glass.js
msgid "Background opacity of glass panels in dark mode (0 = fully transparent, 1 = fully opaque)."
msgstr "Opacité de l'arrière-plan des panneaux en verre en mode sombre (0 = totalement transparent, 1 = totalement opaque)."

#: htdocs/luci-static/resources/view/system/glass.js
msgid "Background"
msgstr "Arrière-plan"

#: htdocs/luci-static/resources/view/system/glass.js
msgid "Current background"
msgstr "Arrière-plan actuel"

#: htdocs/luci-static/resources/view/system/glass.js
msgid "Active"
msgstr "Actif"

#: htdocs/luci-static/resources/view/system/glass.js
msgid "No background set. Upload an image or video named \"bg\" (e.g. bg.jpg, bg.png, bg.mp4) to /www/luci-static/glass/background/ via SCP."
msgstr "Aucun arrière-plan défini. Envoyez une image ou une vidéo nommée «bg» (ex. bg.jpg, bg.png, bg.mp4) vers /www/luci-static/glass/background/ via SCP."
